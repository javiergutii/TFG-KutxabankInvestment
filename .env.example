# =============================================================================
# CONFIGURACIÓN DEL SISTEMA DE PROCESAMIENTO
# =============================================================================

# -----------------------------------------------------------------------------
# MySQL Database
# -----------------------------------------------------------------------------
MYSQL_DATABASE=reports
MYSQL_USER=reports_user
MYSQL_PASSWORD=reports_pass
MYSQL_ROOT_PASSWORD=root_pass

# -----------------------------------------------------------------------------
# Extractor Service
# -----------------------------------------------------------------------------
# URL del video a procesar
TARGET_URL=https://example.com/video

# Información de la empresa
EMPRESA=Telefónica
VIDEO_TITLE=Conference Demo
VIDEO_DATE=2026-02-03 10:00

# Formulario de acceso (si el video requiere registro)
FORM_FIRST_NAME=Javier
FORM_LAST_NAME=Gutiérrez
FORM_EMAIL=javier.g@example.com
FORM_COMPANY=Empresa A
FORM_COUNTRY_TEXT=Spain
FORM_OCCUPATION_TEXT=Analyst

# Configuración de Whisper
WHISPER_MODEL=medium
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8_float32

# Timeout para scraping (milisegundos)
TIMEOUT_MS=45000

# -----------------------------------------------------------------------------
# SharePoint (Opcional)
# -----------------------------------------------------------------------------
SHAREPOINT_ENABLED=false
SHAREPOINT_TENANT_ID=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=
SHAREPOINT_SITE_ID=
SHAREPOINT_DRIVE_ID=
SHAREPOINT_FOLDER=Transcripciones

# -----------------------------------------------------------------------------
# Processor Service
# -----------------------------------------------------------------------------
# Intervalo de procesamiento (segundos)
PROCESSING_INTERVAL=60

# Número de reportes a procesar por batch
BATCH_SIZE=10

# Configuración de chunks de texto
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# -----------------------------------------------------------------------------
# Embeddings Model
# -----------------------------------------------------------------------------
# Modelo de sentence-transformers para generar embeddings
# Opciones:
#   - paraphrase-multilingual-MiniLM-L12-v2 (ligero, multiidioma)
#   - all-MiniLM-L6-v2 (rápido, solo inglés)
#   - paraphrase-multilingual-mpnet-base-v2 (mejor calidad, más pesado)
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# -----------------------------------------------------------------------------
# FAISS Configuration
# -----------------------------------------------------------------------------
FAISS_INDEX_DIR=/app/shared/faiss_index
FAISS_INDEX_FILE=index.faiss
FAISS_METADATA_FILE=metadata.pkl

# -----------------------------------------------------------------------------
# Ollama Configuration
# -----------------------------------------------------------------------------
OLLAMA_HOST=http://ollama:11434

# Modelo a usar (debe estar descargado en Ollama)
# Opciones recomendadas:
#   - llama3.2:3b      (rápido, 2GB RAM)
#   - llama3.1:8b      (mejor calidad, 4.7GB RAM)
#   - mistral:7b       (alternativa rápida)
#   - mixtral:8x7b     (máxima calidad, 26GB RAM)
OLLAMA_MODEL=llama3.2:3b

# Timeout para llamadas a Ollama (segundos)
OLLAMA_TIMEOUT=120

# -----------------------------------------------------------------------------
# Proxy (Opcional)
# -----------------------------------------------------------------------------
# Descomentar si necesitas usar proxy corporativo
# HTTP_PROXY=http://proxy.company.com:8080
# HTTPS_PROXY=http://proxy.company.com:8080
# NO_PROXY=localhost,127.0.0.1,::1,db,ollama
