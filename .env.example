# Activar/Desactivar SharePoint (true/false)
SHAREPOINT_ENABLED=false

# Credenciales de Azure AD (obtener desde Azure Portal)
SHAREPOINT_TENANT_ID=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=

# ID del sitio de SharePoint (obtener usando Graph API)
SHAREPOINT_SITE_ID=

# ID del drive (opcional, se obtiene automáticamente si se deja vacío)
SHAREPOINT_DRIVE_ID=

# Carpeta destino en SharePoint
SHAREPOINT_FOLDER=Transcripciones
